# ─── ET Markets Intelligence Layer — Environment Template ───────────────────
# Copy this file to .env and fill in your values

ENVIRONMENT=development
MOCK_DATA=true
USE_MEMORY_DB=true
USE_FINBERT=true

DATABASE_URL=sqlite+aiosqlite:///./etmarkets.db
REDIS_URL=redis://localhost:6379

ALPHA_VANTAGE_KEY=your_alpha_vantage_key
NEWSAPI_KEY=your_newsapi_key

REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=ETMarkets/1.0
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=gpt-oss-20b

FINBERT_MODEL=ProsusAI/finbert
FINBERT_CACHE_DIR=./models/finbert

SENDGRID_API_KEY=your_sendgrid_key
ALERT_FROM_EMAIL=alerts@etmarkets.ai
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
SECRET_KEY=change-this-in-production
